{
  "name": "emacs-shared",
  "version": "1.0.0",
  "description": "Shared Emacs settings",
  "type": "module",
  "directories": {
    "doc": "doc"
  },
  "bin": {
    "vscode-markdown-language-server": "./node_modules/vscode-markdown-languageserver/dist/node/workerMain.js"
  },
  "scripts": {
    "init": "pnpm run up && pnpm run init:hooks",
    "init:hooks": "lefthook install",
    "hooks:check": "lefthook run pre-commit --all-files --no-stage-fixed",
    "hooks:pre-commit": "lefthook run pre-commit",
    "hooks:pre-commit:all": "lefthook run pre-commit --all-files",
    "fix:md": "prettier --write '**/*.md'",
    "fix:md:file": "prettier --write",
    "fix:yaml": "prettier --write '**/*.yaml'",
    "fix:yaml:file": "prettier --write",
    "test": "echo \"Error: no test specified\" && exit 1",
    "up": "mise use -g node@lts pnpm@latest && mise install && pnpm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/language-server": "^2.16.6",
    "@biomejs/biome": "^2.4.10",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@mwolson/emacs-shared": "link:",
    "@t1ckbase/vscode-langservers-extracted": "1.0.2",
    "@tailwindcss/language-server": "^0.14.29",
    "@vue/language-server": "^3.2.6",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "svelte-language-server": "^0.17.30",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "vscode-markdown-languageserver": "0.5.0-alpha.12"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "tree-sitter-cli": "^0.25.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter-cli"
    ]
  }
}
