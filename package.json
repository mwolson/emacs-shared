{
  "name": "emacs-shared",
  "version": "1.0.0",
  "packageManager": "aube@latest",
  "description": "Shared Emacs settings",
  "type": "module",
  "directories": {
    "doc": "doc"
  },
  "bin": {
    "vscode-markdown-language-server": "./node_modules/vscode-markdown-languageserver/dist/node/workerMain.js"
  },
  "scripts": {
    "init": "aube run up && aube run init:hooks",
    "init:hooks": "lefthook install",
    "hooks:check": "lefthook run pre-commit --all-files --no-stage-fixed",
    "hooks:pre-commit": "lefthook run pre-commit",
    "hooks:pre-commit:all": "lefthook run pre-commit --all-files",
    "fix:md": "prettier --write '**/*.md'",
    "fix:md:file": "prettier --write",
    "fix:yaml": "prettier --write '**/*.yaml'",
    "fix:yaml:file": "prettier --write",
    "test": "echo \"Error: no test specified\" && exit 1",
    "up": "mise install && aube install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/language-server": "^2.16.8",
    "@biomejs/biome": "^2.4.15",
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@mwolson/emacs-shared": "link:",
    "@t1ckbase/vscode-langservers-extracted": "1.0.6",
    "@tailwindcss/language-server": "^0.14.29",
    "@vue/language-server": "^3.2.8",
    "oxlint": "^1.64.0",
    "prettier": "^3.8.3",
    "puppeteer": "^24.43.1",
    "stylelint": "^17.11.0",
    "svelte-language-server": "^0.18.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.2.0",
    "vscode-markdown-languageserver": "0.5.0-alpha.15"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "tree-sitter-cli": "^0.26.8"
  },
  "aube": {
    "allowBuilds": {
      "lefthook": true,
      "puppeteer": false
    }
  }
}
